# Идентификатор сервера/приложения (видна в Kibana как фильтр)
# Примеры: DB_APP-ID, prod-vm1, analytics
# Если БД несколько — итоговый source в ES будет: SOURCE_LABEL_dbname
#   например: DB_APP-ID_entera_app, DB_APP-ID_entera_id
SOURCE_LABEL=DB_APP-ID

# PostgreSQL — источник статистики
PG_HOST=host.docker.internal
PG_PORT=5432
# Список БД через запятую (одна или несколько на одном сервере)
PG_DATABASES=entera_app,entera_id
PG_USER=myuser
PG_PASSWORD=mypassword

# Фильтр запросов (SQL ILIKE)
QUERY_FILTER=%insert%

# Сбрасывать pg_stat_statements после сбора? (true/false)
# false — если pg_stat_statements используется другими инструментами (pgBadger, pg_activity и т.д.)
RESET_STATS=true

# Elasticsearch
ES_HOST=http://your-elastic-host:9200
ES_USER=elastic
ES_PASSWORD=changeme
ES_INDEX=pg-query-stats

# Kibana (только для setup_kibana.py)
KIBANA_HOST=http://your-kibana-host:5601
KIBANA_USER=elastic
KIBANA_PASSWORD=changeme
